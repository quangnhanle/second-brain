  "fileRules": [
    {
      "id": "tIUjF",
      "name": "Todo",
      "match": "all",
      "conditions": [
        {
          "source": "path",
          "operator": "contains",
          "value": "Todo"
        },
        {
          "source": "created",
          "operator": "isToday"
        }
      ],
      "enabled": true,
      "icon": "lucide-layout-list"
    },
    {
      "id": "RjidT",
      "name": "Done-Todo",
      "match": "all",
      "conditions": [
        {
          "source": "path",
          "operator": "contains",
          "value": "Todo"
        },
        {
          "source": "created",
          "operator": "!isToday"
        }
      ],
      "enabled": true,
      "icon": "lucide-list-check"
    },
    {
      "id": "h7umk",
      "name": "File",
      "match": "all",
      "conditions": [
        {
          "source": "filename",
          "operator": "endsWith",
          "value": "md"
        }
      ],
      "enabled": true,
      "color": "#777879",
      "icon": "lucide-notebook-text"
    }
  ],
